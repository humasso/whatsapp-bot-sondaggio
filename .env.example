# Usa uno tra TARGET_GROUP_JID e TARGET_GROUP_NAME.
# JID gruppo: di solito termina con @g.us. Se non lo sai, avvia con TARGET_GROUP_NAME.
TARGET_GROUP_JID=
TARGET_GROUP_NAME=

# Opzione da cliccare. Se POLL_OPTION_TEXT e' valorizzato, ha priorita' sull'indice.
POLL_OPTION_INDEX=0
POLL_OPTION_TEXT=

# Se true, non invia davvero il voto: stampa solo cosa farebbe.
DRY_RUN=false

# Ritardo opzionale prima del voto, in millisecondi.
VOTE_DELAY_MS=0

# Se true, ignora i sondaggi creati dallo stesso account collegato al bot.
IGNORE_OWN_POLLS=false

# Directory sessione WhatsApp. Contiene credenziali locali: non committarla.
SESSION_DIR=.session
